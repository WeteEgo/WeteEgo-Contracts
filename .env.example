# RPC URLs (used by forge script if --rpc-url not passed)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Do NOT put PRIVATE_KEY here. Export it in your shell before running forge script:
#   export PRIVATE_KEY=0x...
# Or pass it at deploy time: --private-key $PRIVATE_KEY

# Settlement address (e.g. Paycrest gateway or test EOA for Base Sepolia)
SETTLEMENT_ADDRESS=0x...

# Address allowed to call settleOrder() (e.g. backend service wallet)
SETTLER_ADDRESS=0x...

# Basescan API key for contract verification (optional if you pass --etherscan-api-key)
BASESCAN_API_KEY=
